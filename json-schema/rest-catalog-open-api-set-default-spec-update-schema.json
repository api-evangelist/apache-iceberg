{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-iceberg/refs/heads/main/json-schema/rest-catalog-open-api-set-default-spec-update-schema.json",
  "title": "SetDefaultSpecUpdate",
  "description": "SetDefaultSpecUpdate schema from Apache Iceberg REST Catalog API",
  "properties": {
    "action": {
      "type": "string",
      "const": "set-default-spec"
