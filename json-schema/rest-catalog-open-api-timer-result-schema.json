{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-iceberg/refs/heads/main/json-schema/rest-catalog-open-api-timer-result-schema.json",
  "title": "TimerResult",
  "description": "TimerResult schema from Apache Iceberg REST Catalog API",
  "type": "object",
  "properties": {
    "time-unit": {
      "type": "string"
    },
    "count": {
      "type": "integer",
      "format": "int64"
    },
    "total-duration": {
      "type": "integer",
      "format": "int64"
    }
  },
  "required": [
    "time-unit",
    "count",
    "total-duration"
  ]
}